{
  "name": "tutor",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:design": "ng serve --configuration=design --port 4300",
    "start:prod": "ng serve --configuration=production --port 4400",
    "start:prod:design": "ng serve --configuration=production-design --port 4401",
    "prestart": "node scripts/prepare-environment.mjs development",
    "prestart:design": "node scripts/prepare-environment.mjs design",
    "prestart:prod": "node scripts/prepare-environment.mjs production",
    "prestart:prod:design": "node scripts/prepare-environment.mjs production-design",
    "build": "ng build --configuration production",
    "prebuild": "node scripts/prepare-environment.mjs production",
    "build:hosting": "node scripts/prepare-environment.mjs production-design && ng build --configuration=production-design",
    "build:dev": "ng build --configuration development",
    "prebuild:dev": "node scripts/prepare-environment.mjs development",
    "watch": "ng build --watch --configuration development",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:backend": "npm test --prefix backend",
    "serve:ssr:tutor": "node dist/tutor/server/server.mjs"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@11.6.2",
  "dependencies": {
    "@angular/cdk": "21.2.12",
    "@angular/common": "21.2.12",
    "@angular/compiler": "21.2.12",
    "@angular/core": "21.2.12",
    "@angular/fire": "21.0.0-rc.0",
    "@angular/forms": "21.2.12",
    "@angular/platform-browser": "21.2.12",
    "@angular/platform-browser-dynamic": "21.2.12",
    "@angular/platform-server": "21.2.12",
    "@angular/router": "21.2.12",
    "@angular/ssr": "21.2.12",
    "express": "^5.1.0",
    "firebase": "^12.13.0",
    "pdfmake": "^0.3.11",
    "rrule": "^2.8.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "21.2.12",
    "@angular/cli": "21.2.12",
    "@angular/compiler-cli": "21.2.12",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/pdfmake": "^0.3.3",
    "jsdom": "^27.1.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
